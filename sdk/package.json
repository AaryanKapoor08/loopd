{
  "name": "@loopd/sdk",
  "version": "0.0.0",
  "private": true,
  "description": "TypeScript SDK for loopd (Surface 2): wrap programmatic / API / framework agent loops so they appear in the loopd cockpit and obey its governance. Wire types are generated from the Rust core via ts-rs.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "keywords": [
    "ai",
    "agents",
    "loopd",
    "governance",
    "observability"
  ],
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@types/node": "^22.13.1",
    "typescript": "^5.7.3"
  }
}
